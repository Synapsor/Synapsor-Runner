{
  "name": "synapsor-runner-monorepo",
  "private": true,
  "version": "1.1.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "synapsor-runner": "./bin/synapsor-runner"
  },
  "scripts": {
    "build": "tsc -b",
    "build:runner-package": "tsc -b && node scripts/build-runner-package.mjs",
    "clean": "find . -path '*/dist' -type d -prune -exec rm -rf {} +",
    "lint": "tsc -b --pretty false",
    "test": "tsc -b --pretty false && vitest run && node scripts/check-license-content.mjs && ./scripts/verify-dsl-source-paths.sh",
    "test:license-content": "node scripts/check-license-content.mjs",
    "test:smoke": "./scripts/verify-release-gate.sh",
    "test:docker": "node scripts/smoke-local-examples.mjs",
    "test:mcp-local": "node scripts/smoke-mcp-local-examples.mjs",
    "test:live-apply": "node scripts/smoke-mcp-local-examples.mjs",
    "test:fleet": "corepack pnpm build && node scripts/verify-runner-fleet.mjs",
    "test:mcp-cloud-linked": "tsc -b --pretty false && node scripts/smoke-mcp-cloud-linked.mjs",
    "test:onboarding-generated": "tsc -b --pretty false && node scripts/smoke-generated-onboarding.mjs",
    "test:init-own-db": "tsc -b --pretty false && node scripts/smoke-generated-onboarding.mjs",
    "test:mcp-streamable": "vitest run packages/mcp-server/src/index.test.ts apps/runner/src/cli.test.ts",
    "test:mcp-audit": "vitest run apps/runner/src/cli.test.ts",
    "test:reference-app": "tsc -b --pretty false && node scripts/smoke-reference-support-billing-app.mjs",
    "test:app-owned-executor": "examples/mcp-postgres-billing-app-handler/scripts/run-demo.sh",
    "verify:hosted-cloud-linked": "tsc -b --pretty false && node scripts/verify-hosted-cloud-linked.mjs",
    "test:mcp-client-configs": "node scripts/verify-mcp-client-configs.mjs",
    "demo:docker": "./scripts/demo-docker.sh",
    "demo:local": "./scripts/demo-local.sh",
    "demo:ui": "./scripts/open-demo-ui.sh",
    "mcp:config": "./scripts/mcp-config.sh",
    "typecheck": "tsc -b --pretty false",
    "synapsor-runner": "tsx apps/runner/src/cli.ts",
    "runner": "tsx apps/runner/src/cli.ts",
    "demo:reference": "./scripts/run-reference-app.sh",
    "demo:video": "./scripts/demo-video/build-video.sh",
    "demo:video:check": "./scripts/demo-video/check-prerequisites.sh",
    "demo:video:reset": "./scripts/demo-video/reset.sh",
    "demo:video:capture": "./scripts/demo-video/capture-terminal.sh",
    "demo:video:verify": "./scripts/demo-video/verify-video.sh",
    "test:first-run": "./scripts/try-synapsor.sh",
    "own-db": "./scripts/use-your-db.sh",
    "verify:local-runner": "./scripts/verify-local-runner.sh",
    "verify:adoption": "./scripts/verify_adoption_quickstart.sh",
    "verify:dsl-sources": "./scripts/verify-dsl-source-paths.sh",
    "verify:public-commands": "./scripts/verify-public-commands.sh",
    "verify:packed-runner": "./scripts/verify-packed-runner.sh",
    "verify:packed-own-db": "./scripts/verify-packed-own-db.sh",
    "verify:published-alpha": "./scripts/verify-published-alpha.sh"
  },
  "devDependencies": {
    "@synapsor-runner/config": "workspace:*",
    "@synapsor-runner/control-plane-client": "workspace:*",
    "@synapsor-runner/mcp-server": "workspace:*",
    "@synapsor-runner/mysql": "workspace:*",
    "@synapsor-runner/postgres": "workspace:*",
    "@synapsor-runner/proposal-store": "workspace:*",
    "@synapsor-runner/protocol": "workspace:*",
    "@synapsor-runner/schema-inspector": "workspace:*",
    "@synapsor-runner/worker-core": "workspace:*",
    "@synapsor/dsl": "workspace:*",
    "@synapsor/handler": "workspace:*",
    "@synapsor/spec": "workspace:*",
    "@types/node": "^22.10.0",
    "esbuild": "0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
