{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.synapsor.ai/synapsor-contract.schema.json",
  "title": "Synapsor Contract",
  "type": "object",
  "required": ["spec_version", "kind", "contexts", "capabilities"],
  "additionalProperties": false,
  "patternProperties": {
    "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
  },
  "properties": {
    "spec_version": { "const": "0.1" },
    "kind": { "const": "SynapsorContract" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/context" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    },
    "workflows": {
      "type": "array",
      "items": { "$ref": "#/$defs/workflow" }
    },
    "policies": {
      "type": "array",
      "items": { "$ref": "#/$defs/policy" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRecord" }
    },
    "proposals": {
      "type": "array",
      "items": { "$ref": "#/$defs/proposalRecord" }
    },
    "receipts": {
      "type": "array",
      "items": { "$ref": "#/$defs/receipt" }
    },
    "replay": {
      "type": "array",
      "items": { "$ref": "#/$defs/replay" }
    },
    "external_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/externalAction" }
    }
  },
  "$defs": {
    "safeIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "qualifiedName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$"
    },
    "qualifiedOrSafeName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)?$"
    },
    "scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "extensionAware": {
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      }
    },
    "resource": {
      "type": "object",
      "required": ["name", "engine", "schema", "table", "primary_key"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "engine": { "enum": ["postgres", "mysql", "synapsor"] },
        "schema": { "$ref": "#/$defs/safeIdentifier" },
        "table": { "$ref": "#/$defs/safeIdentifier" },
        "type": { "enum": ["table", "view", "external_source"] },
        "primary_key": { "$ref": "#/$defs/safeIdentifier" },
        "tenant_key": { "$ref": "#/$defs/safeIdentifier" },
        "conflict_key": { "$ref": "#/$defs/safeIdentifier" },
        "single_tenant_dev": { "type": "boolean" }
      }
    },
    "binding": {
      "type": "object",
      "required": ["name", "source", "key"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/safeIdentifier" },
        "source": { "enum": ["session", "environment", "cloud_session", "static_dev", "http_claim"] },
        "key": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      }
    },
    "context": {
      "type": "object",
      "required": ["name", "bindings"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "description": { "type": "string" },
        "bindings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/binding" } },
        "tenant_binding": { "$ref": "#/$defs/safeIdentifier" },
        "principal_binding": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "arg": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "type": { "enum": ["string", "number", "boolean", "object_array"] },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "max_length": { "type": "integer", "minimum": 1 },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "enum": { "type": "array", "items": { "$ref": "#/$defs/scalar" } },
        "max_items": { "type": "integer", "minimum": 1, "maximum": 100 },
        "fields": { "type": "object", "minProperties": 1, "maxProperties": 64, "additionalProperties": { "$ref": "#/$defs/arg" } }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "resource": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "schema": { "$ref": "#/$defs/safeIdentifier" },
        "table": { "$ref": "#/$defs/safeIdentifier" },
        "primary_key": { "$ref": "#/$defs/safeIdentifier" },
        "tenant_key": { "$ref": "#/$defs/safeIdentifier" },
        "principal_scope_key": { "$ref": "#/$defs/safeIdentifier" },
        "conflict_key": { "$ref": "#/$defs/safeIdentifier" },
        "single_tenant_dev": { "type": "boolean" }
      }
    },
    "evidenceRequirement": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "required": { "type": "boolean" },
        "sources": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "query_audit": { "type": "boolean" },
        "handle_prefix": { "type": "string" }
      }
    },
    "patchBinding": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "fixed": { "$ref": "#/$defs/scalar" },
        "from_arg": { "$ref": "#/$defs/safeIdentifier" },
        "from_item": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "proposalAction": {
      "type": "object",
      "required": ["action", "allowed_fields", "patch"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "action": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "operation": { "$ref": "#/$defs/proposalOperation" },
        "allowed_fields": { "type": "array", "items": { "$ref": "#/$defs/safeIdentifier" } },
        "patch": { "type": "object", "additionalProperties": { "$ref": "#/$defs/patchBinding" } },
        "numeric_bounds": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/numericBound" }
        },
        "transition_guards": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/transitionGuard" }
        },
        "reversibility": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": { "const": "reviewed_inverse" }
          }
        },
        "conflict_guard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "column": { "$ref": "#/$defs/safeIdentifier" },
            "weak_guard_ack": { "type": "boolean" }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "enum": ["human", "operator", "policy"] },
            "required_role": { "type": "string" },
            "required_approvals": { "type": "integer", "minimum": 1, "maximum": 10 },
            "policy": { "$ref": "#/$defs/qualifiedOrSafeName" }
          }
        },
        "writeback": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": { "enum": ["direct_sql", "app_handler", "cloud_worker", "none"] },
            "executor": { "type": "string" },
            "idempotency_key": { "type": "string" }
          }
        }
      }
    },
    "proposalOperation": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "kind": { "enum": ["update", "insert", "delete"] },
        "cardinality": { "enum": ["single", "set"] },
        "selection": {
          "type": "object",
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "$ref": "#/$defs/fixedPredicateTerm" } }
          }
        },
        "max_rows": { "type": "integer", "minimum": 1, "maximum": 100 },
        "aggregate_bounds": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "$ref": "#/$defs/aggregateBound" } },
        "batch": {
          "type": "object",
          "required": ["items_from_arg"],
          "additionalProperties": false,
          "properties": { "items_from_arg": { "$ref": "#/$defs/safeIdentifier" } }
        },
        "deduplication": {
          "type": "object",
          "required": ["components"],
          "additionalProperties": false,
          "properties": {
            "components": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": { "$ref": "#/$defs/deduplicationComponent" }
            }
          }
        },
        "version_advance": {
          "type": "object",
          "required": ["column", "strategy"],
          "additionalProperties": false,
          "properties": {
            "column": { "$ref": "#/$defs/safeIdentifier" },
            "strategy": { "enum": ["integer_increment", "database_generated"] }
          }
        }
      }
    },
    "deduplicationComponent": {
      "type": "object",
      "required": ["column", "source"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "column": { "$ref": "#/$defs/safeIdentifier" },
        "source": { "enum": ["proposal_id", "trusted_tenant", "fixed", "item_field"] },
        "fixed": { "$ref": "#/$defs/scalar" },
        "item_field": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "fixedPredicateTerm": {
      "type": "object",
      "required": ["column", "operator", "value"],
      "additionalProperties": false,
      "properties": {
        "column": { "$ref": "#/$defs/safeIdentifier" },
        "operator": { "const": "eq" },
        "value": { "$ref": "#/$defs/scalar" }
      }
    },
    "aggregateBound": {
      "type": "object",
      "required": ["column", "measure", "maximum"],
      "additionalProperties": false,
      "properties": {
        "column": { "$ref": "#/$defs/safeIdentifier" },
        "measure": { "enum": ["before", "after", "absolute_delta"] },
        "maximum": { "type": "number", "minimum": 0 }
      }
    },
    "aggregateRead": {
      "type": "object",
      "required": ["function", "minimum_group_size"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "function": { "enum": ["count", "sum", "avg"] },
        "count_mode": { "enum": ["rows", "non_null"] },
        "column": { "$ref": "#/$defs/safeIdentifier" },
        "selection": {
          "type": "object",
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "$ref": "#/$defs/fixedPredicateTerm" } }
          }
        },
        "minimum_group_size": { "type": "integer", "minimum": 2, "maximum": 1000000 }
      }
    },
    "protectedReadValue": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "fixed": { "$ref": "#/$defs/scalar" },
        "from_arg": { "$ref": "#/$defs/safeIdentifier" }
      },
      "oneOf": [
        {
          "required": ["fixed"],
          "not": { "required": ["from_arg"] }
        },
        {
          "required": ["from_arg"],
          "not": { "required": ["fixed"] }
        }
      ]
    },
    "protectedReadPredicate": {
      "type": "object",
      "required": ["field", "operator"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "relationship": { "$ref": "#/$defs/safeIdentifier" },
        "operator": { "enum": ["eq", "neq", "lt", "lte", "gt", "gte", "in"] },
        "value": { "$ref": "#/$defs/protectedReadValue" },
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "$ref": "#/$defs/scalar" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "operator": { "const": "in" } },
            "required": ["operator"]
          },
          "then": {
            "required": ["values"],
            "not": { "required": ["value"] }
          },
          "else": {
            "required": ["value"],
            "not": { "required": ["values"] }
          }
        }
      ]
    },
    "protectedReadRelationship": {
      "type": "object",
      "required": ["name", "schema", "table", "primary_key", "tenant_key", "local_key", "target_key", "cardinality", "max_fan_out"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/safeIdentifier" },
        "schema": { "$ref": "#/$defs/safeIdentifier" },
        "table": { "$ref": "#/$defs/safeIdentifier" },
        "primary_key": { "$ref": "#/$defs/safeIdentifier" },
        "tenant_key": { "$ref": "#/$defs/safeIdentifier" },
        "principal_scope_key": { "$ref": "#/$defs/safeIdentifier" },
        "local_key": { "$ref": "#/$defs/safeIdentifier" },
        "target_key": { "$ref": "#/$defs/safeIdentifier" },
        "cardinality": { "const": "many_to_one" },
        "max_fan_out": { "const": 1 }
      }
    },
    "protectedReadMeasure": {
      "type": "object",
      "required": ["name", "function"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/safeIdentifier" },
        "function": { "enum": ["count", "count_distinct", "sum", "avg"] },
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "relationship": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "protectedReadDimension": {
      "type": "object",
      "required": ["name", "field"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/safeIdentifier" },
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "relationship": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "protectedReadTimeBucket": {
      "type": "object",
      "required": ["name", "field", "bucket"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/safeIdentifier" },
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "bucket": { "enum": ["day", "week", "month"] },
        "relationship": { "$ref": "#/$defs/safeIdentifier" }
      }
    },
    "protectedReadAggregate": {
      "type": "object",
      "required": ["counted_entity", "measures", "top_n", "minimum_group_size"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "counted_entity": { "const": "subject" },
        "measures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/protectedReadMeasure" }
        },
        "dimensions": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/protectedReadDimension" }
        },
        "time_bucket": { "$ref": "#/$defs/protectedReadTimeBucket" },
        "comparison": {
          "type": "object",
          "required": ["field", "ranges"],
          "additionalProperties": false,
          "properties": {
            "field": { "$ref": "#/$defs/safeIdentifier" },
            "relationship": { "$ref": "#/$defs/safeIdentifier" },
            "ranges": {
              "type": "array",
              "minItems": 1,
              "maxItems": 2,
              "items": {
                "type": "object",
                "required": ["start", "end"],
                "additionalProperties": false,
                "properties": {
                  "start": { "$ref": "#/$defs/protectedReadValue" },
                  "end": { "$ref": "#/$defs/protectedReadValue" }
                }
              }
            }
          }
        },
        "order_by": {
          "type": "object",
          "required": ["kind", "direction"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["measure", "time_bucket"] },
            "measure": { "$ref": "#/$defs/safeIdentifier" },
            "direction": { "enum": ["asc", "desc"] }
          }
        },
        "top_n": { "type": "integer", "minimum": 1, "maximum": 100 },
        "minimum_group_size": { "type": "integer", "minimum": 2, "maximum": 1000000 }
      }
    },
    "protectedReadLimits": {
      "type": "object",
      "required": [
        "max_rows",
        "max_groups",
        "max_response_cells",
        "max_response_bytes",
        "statement_timeout_ms",
        "max_queries_per_session",
        "max_extracted_cells_per_session",
        "max_differencing_queries",
        "rate_limit_per_minute"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "max_rows": { "type": "integer", "minimum": 1, "maximum": 100 },
        "max_groups": { "type": "integer", "minimum": 1, "maximum": 100 },
        "max_response_cells": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "max_response_bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "statement_timeout_ms": { "type": "integer", "minimum": 1, "maximum": 30000 },
        "max_queries_per_session": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "max_extracted_cells_per_session": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_differencing_queries": { "type": "integer", "minimum": 1, "maximum": 100 },
        "rate_limit_per_minute": { "type": "integer", "minimum": 1, "maximum": 120 }
      }
    },
    "protectedRead": {
      "type": "object",
      "required": ["version", "mode", "boundary_digest", "generation_lock_fingerprint", "limits"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "version": { "const": "1" },
        "mode": { "enum": ["rows", "aggregate"] },
        "boundary_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "generation_lock_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "predicates": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/protectedReadPredicate" }
        },
        "relationship": { "$ref": "#/$defs/protectedReadRelationship" },
        "row_order_by": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["field", "direction"],
            "additionalProperties": false,
            "properties": {
              "field": { "$ref": "#/$defs/safeIdentifier" },
              "direction": { "enum": ["asc", "desc"] }
            }
          }
        },
        "aggregate": { "$ref": "#/$defs/protectedReadAggregate" },
        "limits": { "$ref": "#/$defs/protectedReadLimits" }
      }
    },
    "numericBound": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "anyOf": [
        { "required": ["minimum"] },
        { "required": ["maximum"] }
      ]
    },
    "transitionGuard": {
      "type": "object",
      "required": ["allowed"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "from_column": { "$ref": "#/$defs/safeIdentifier" },
        "allowed": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "required": ["name", "kind", "context", "subject", "args", "visible_fields"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/qualifiedName" },
        "description": { "type": "string" },
        "returns_hint": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["read", "aggregate_read", "proposal", "external_action", "answer_with_evidence"] },
        "context": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "source": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "subject": { "$ref": "#/$defs/subject" },
        "args": { "type": "object", "additionalProperties": { "$ref": "#/$defs/arg" } },
        "lookup": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "id_from_arg": { "$ref": "#/$defs/safeIdentifier" } }
        },
        "visible_fields": { "type": "array", "items": { "$ref": "#/$defs/safeIdentifier" } },
        "kept_out_fields": { "type": "array", "items": { "$ref": "#/$defs/safeIdentifier" } },
        "evidence": { "$ref": "#/$defs/evidenceRequirement" },
        "max_rows": { "type": "integer", "minimum": 1 },
        "proposal": { "$ref": "#/$defs/proposalAction" },
        "aggregate": { "$ref": "#/$defs/aggregateRead" },
        "protected_read": { "$ref": "#/$defs/protectedRead" }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["name", "context", "allowed_capabilities"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "name": { "$ref": "#/$defs/qualifiedName" },
        "description": { "type": "string" },
        "context": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "allowed_capabilities": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/qualifiedName" } },
        "required_evidence": { "type": "boolean" },
        "approval": { "type": "object" },
        "settlement": { "type": "object" },
        "replay": { "type": "object" }
      }
    },
    "policy": {
      "type": "object",
      "required": ["name", "kind"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "approval" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "rules": {
                "type": "array",
                "items": { "$ref": "#/$defs/approvalPolicyRule" }
              },
              "limits": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/approvalPolicyLimit" }
              }
            }
          }
        }
      ],
      "properties": {
        "name": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "kind": { "enum": ["approval", "settlement", "scope", "custom"] },
        "mode": { "enum": ["green", "yellow", "red", "manual", "block"] },
        "rules": { "type": "array", "items": { "type": "object" } },
        "limits": { "type": "array", "items": { "type": "object" } }
      }
    },
    "approvalPolicyRule": {
      "type": "object",
      "required": ["field", "max"],
      "additionalProperties": false,
      "properties": {
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "approvalPolicyLimit": {
      "type": "object",
      "required": ["kind", "max", "period"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "total" } }, "required": ["kind"] },
          "then": { "required": ["field"] },
          "else": { "not": { "required": ["field"] } }
        }
      ],
      "properties": {
        "kind": { "enum": ["count", "total"] },
        "max": { "type": "integer", "minimum": 0 },
        "period": { "const": "day" },
        "field": { "$ref": "#/$defs/safeIdentifier" },
        "scope": { "enum": ["tenant_policy", "tenant_policy_object"] }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "required": ["handle"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "handle": { "type": "string" },
        "capability": { "$ref": "#/$defs/qualifiedName" },
        "query_fingerprint": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } }
      }
    },
    "proposalRecord": {
      "type": "object",
      "required": ["id", "capability", "subject", "status"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "id": { "type": "string" },
        "capability": { "$ref": "#/$defs/qualifiedName" },
        "subject": { "type": "object" },
        "status": { "enum": ["pending", "approved", "rejected", "canceled", "applied", "conflict", "failed"] },
        "diff": { "type": "object" },
        "evidence_handle": { "type": "string" }
      }
    },
    "receipt": {
      "type": "object",
      "required": ["id", "proposal_id", "status", "source_database_mutated"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "id": { "type": "string" },
        "proposal_id": { "type": "string" },
        "status": { "enum": ["applied", "already_applied", "conflict", "failed", "canceled"] },
        "idempotency_key": { "type": "string" },
        "source_database_mutated": { "type": "boolean" },
        "rows_affected": { "type": "integer", "minimum": 0 }
      }
    },
    "replay": {
      "type": "object",
      "required": ["id", "events"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "id": { "type": "string" },
        "proposal_id": { "type": "string" },
        "run_id": { "type": "string" },
        "events": { "type": "array", "items": { "type": "object" } }
      }
    },
    "externalAction": {
      "type": "object",
      "required": ["id", "action"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-(cloud|runner|experimental)-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "id": { "type": "string" },
        "action": { "$ref": "#/$defs/qualifiedOrSafeName" },
        "handler": { "type": "string" },
        "idempotency_key": { "type": "string" },
        "receipt": { "type": "string" }
      }
    }
  }
}
