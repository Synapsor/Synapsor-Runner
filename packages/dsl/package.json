{
  "name": "@synapsor/dsl",
  "version": "0.1.0",
  "description": "Preview SQL-like Synapsor authoring DSL compiler for canonical @synapsor/spec contracts.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
