{
  "servers": {
    "synapsor": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "@synapsor/runner",
        "synapsor-runner",
        "mcp",
        "serve",
        "--config",
        "./examples/support-plan-credit/synapsor.runner.json",
        "--store",
        "./tmp/support-plan-credit/local.db"
      ]
    }
  }
}
