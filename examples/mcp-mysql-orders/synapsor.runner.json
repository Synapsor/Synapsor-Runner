{
  "version": 1,
  "mode": "review",
  "storage": {
    "sqlite_path": "./tmp/mcp-mysql-orders/local.db"
  },
  "sources": {
    "app_mysql_orders": {
      "engine": "mysql",
      "read_url_env": "ORDERS_MYSQL_READ_URL",
      "write_url_env": "ORDERS_MYSQL_WRITE_URL",
      "statement_timeout_ms": 3000
    }
  },
  "trusted_context": {
    "provider": "environment",
    "values": {
      "tenant_id_env": "SYNAPSOR_TENANT_ID",
      "principal_env": "SYNAPSOR_PRINCIPAL"
    }
  },
  "capabilities": [
    {
      "name": "orders.inspect_order",
      "kind": "read",
      "source": "app_mysql_orders",
      "target": {
        "schema": "synapsor_runner_mcp_orders",
        "table": "orders",
        "primary_key": "id",
        "tenant_key": "tenant_id"
      },
      "args": {
        "order_id": {
          "type": "string",
          "required": true,
          "max_length": 128
        }
      },
      "lookup": {
        "id_from_arg": "order_id"
      },
      "visible_columns": [
        "id",
        "tenant_id",
        "customer_name",
        "status",
        "refund_review_status",
        "refund_note",
        "updated_at"
      ],
      "evidence": "required",
      "max_rows": 1
    },
    {
      "name": "orders.propose_refund_review",
      "kind": "proposal",
      "source": "app_mysql_orders",
      "target": {
        "schema": "synapsor_runner_mcp_orders",
        "table": "orders",
        "primary_key": "id",
        "tenant_key": "tenant_id"
      },
      "args": {
        "order_id": {
          "type": "string",
          "required": true,
          "max_length": 128
        },
        "refund_note": {
          "type": "string",
          "required": true,
          "max_length": 500
        }
      },
      "lookup": {
        "id_from_arg": "order_id"
      },
      "visible_columns": [
        "id",
        "tenant_id",
        "customer_name",
        "status",
        "refund_review_status",
        "refund_note",
        "updated_at"
      ],
      "evidence": "required",
      "max_rows": 1,
      "patch": {
        "refund_review_status": {
          "fixed": "review_required"
        },
        "refund_note": {
          "from_arg": "refund_note"
        }
      },
      "allowed_columns": [
        "refund_review_status",
        "refund_note"
      ],
      "conflict_guard": {
        "column": "updated_at"
      },
      "approval": {
        "mode": "human",
        "required_role": "orders_lead"
      }
    }
  ]
}
