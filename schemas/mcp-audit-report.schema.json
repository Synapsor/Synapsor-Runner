{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapsor.ai/schemas/mcp-audit-report.schema.json",
  "title": "Synapsor MCP Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target",
    "disclaimer",
    "generated_at",
    "summary",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "synapsor.mcp-audit.v1"
    },
    "target": {
      "type": "string"
    },
    "disclaimer": {
      "const": "This is a static risk review, not proof that an MCP server is secure."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tools_inspected",
        "high",
        "medium",
        "low",
        "total_findings"
      ],
      "properties": {
        "tools_inspected": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "total_findings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "code",
          "message",
          "evidence",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "code": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    }
  }
}
