{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapsor.ai/schemas/mcp-audit-report.schema.json",
  "title": "Synapsor MCP Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target",
    "disclaimer",
    "generated_at",
    "summary",
    "authority_map",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "synapsor.mcp-audit.v1"
    },
    "target": {
      "type": "string"
    },
    "disclaimer": {
      "const": "This is a static risk review, not proof that an MCP server is secure."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tools_inspected",
        "high",
        "medium",
        "low",
        "total_findings"
      ],
      "properties": {
        "tools_inspected": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "total_findings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "authority_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items",
        "visibility_limit"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "authority",
              "label",
              "status",
              "tools",
              "evidence"
            ],
            "properties": {
              "authority": { "type": "string" },
              "label": { "type": "string" },
              "status": {
                "enum": [
                  "observed",
                  "not_observed",
                  "requires_operator_verification",
                  "outside_static_audit_visibility"
                ]
              },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence": { "type": "string" }
            }
          }
        },
        "visibility_limit": { "type": "string" }
      }
    },
    "bypass_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "servers",
        "direct_bypass_observed",
        "unverified_servers",
        "warning"
      ],
      "properties": {
        "mode": {
          "enum": ["static_config", "selected_live_tools_list"]
        },
        "servers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "server",
              "status",
              "transport",
              "tools_observed",
              "evidence",
              "remediation"
            ],
            "properties": {
              "server": { "type": "string" },
              "status": {
                "enum": [
                  "observed_direct_authority",
                  "no_direct_authority_observed",
                  "requires_operator_verification"
                ]
              },
              "transport": { "enum": ["stdio", "remote", "unknown"] },
              "tools_observed": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence": { "type": "string" },
              "remediation": { "type": "string" }
            }
          }
        },
        "direct_bypass_observed": { "type": "boolean" },
        "unverified_servers": { "type": "integer", "minimum": 0 },
        "warning": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "code",
          "message",
          "evidence",
          "recommendation",
          "remediation_url"
        ],
        "properties": {
          "severity": {
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "code": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendation": {
            "type": "string"
          },
          "remediation_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
