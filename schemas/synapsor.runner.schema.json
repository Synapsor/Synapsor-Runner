{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapsor.ai/schemas/synapsor.runner.schema.json",
  "title": "Synapsor Runner config",
  "description": "Configuration for local Synapsor Runner MCP capabilities over Postgres/MySQL.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode"],
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "cloud" } }, "required": ["mode"] },
      "then": { "required": ["cloud"] },
      "else": { "required": ["sources"] }
    },
    {
      "if": { "required": ["contracts"] },
      "then": {},
      "else": {
        "if": { "properties": { "mode": { "not": { "const": "cloud" } } }, "required": ["mode"] },
        "then": {
          "required": ["capabilities"],
          "properties": { "capabilities": { "minItems": 1 } },
          "anyOf": [
            { "required": ["trusted_context"] },
            { "required": ["contexts"] }
          ]
        }
      }
    }
  ],
  "properties": {
    "version": {
      "description": "Runner configuration contract version. Version 1 is the current public format.",
      "const": 1
    },
    "mode": {
      "description": "Local execution mode. review permits proposals and trusted writeback; cloud delegates reviewed tools to Synapsor Cloud.",
      "type": "string",
      "enum": ["read_only", "shadow", "review", "cloud"]
    },
    "result_format": {
      "description": "Set to 2 to return one stable ok/summary/data/proposal/error envelope from MCP tool calls.",
      "type": "integer",
      "enum": [1, 2],
      "default": 1
    },
    "strict": {
      "description": "Reject unknown configuration keys when true.",
      "type": "boolean",
      "default": true
    },
    "storage": {
      "description": "Local proposal, evidence, receipt, and replay ledger. Relative sqlite_path values resolve from the Runner process working directory.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sqlite_path": {
          "description": "SQLite ledger path. The file can contain visible business-data evidence and is created with owner-only permissions on POSIX.",
          "type": "string",
          "minLength": 1
        },
        "shared_postgres": {
          "description": "Optional shared Postgres ledger. mode=mirror coordinates bounded CLI mutations with a schema-scoped advisory lock while the live runtime store remains local SQLite. mode=runtime_store makes MCP serving use Postgres as the primary proposal/evidence/replay store.",
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "url_env"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["mirror", "runtime_store", "disabled"]
            },
            "url_env": {
              "description": "Environment variable containing the shared ledger Postgres URL. The URL itself must not be stored in config.",
              "type": "string",
              "pattern": "^[A-Z_][A-Z0-9_]*$"
            },
            "schema": {
              "description": "Postgres schema for shared ledger tables.",
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "default": "synapsor_runner"
            },
            "lock_timeout_ms": {
              "description": "How long mirror-mode CLI commands wait for the schema-scoped advisory lock.",
              "type": "integer",
              "minimum": 0,
              "default": 10000
            },
            "max_entries": {
              "description": "Safety bound for the bounded runtime-store bridge. Operations fail closed rather than copying an unbounded ledger.",
              "type": "integer",
              "minimum": 100,
              "maximum": 100000,
              "default": 10000
            }
          }
        }
      }
    },
    "sources": {
      "description": "Named Postgres/MySQL sources. Contract SOURCE names must match these keys.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/source"
      }
    },
    "trusted_context": {
      "description": "Default operator-controlled tenant/principal binding. These values are never model arguments.",
      "$ref": "#/$defs/trusted_context"
    },
    "contexts": {
      "description": "Named trusted contexts referenced by capabilities or portable contracts.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/trusted_context"
      }
    },
    "executors": {
      "description": "Trusted app-owned writeback executors. URLs, tokens, and commands are referenced through environment-variable names.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/executor"
      }
    },
    "contracts": {
      "description": "Portable @synapsor/spec contract files. Relative paths resolve from this config file's directory.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capabilities": {
      "description": "Embedded compatibility capabilities. May be empty when contracts supplies the capability catalog.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "policies": {
      "description": "Embedded reviewed policies. Contract-authored policies are merged into the same runtime catalog.",
      "type": "array",
      "items": { "$ref": "#/$defs/policy" }
    },
    "approvals": {
      "description": "Local approval behavior overrides.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disable_auto_approval": { "type": "boolean" }
      }
    },
    "rate_limits": {
      "description": "Operational fixed-window request limits keyed from verified tenant context and reviewed capability. These are deployment controls, not portable contract policy.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "default": { "$ref": "#/$defs/rate_limit_rule" },
        "capabilities": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/qualified_name" },
          "additionalProperties": { "$ref": "#/$defs/rate_limit_rule" }
        }
      }
    },
    "metrics": {
      "description": "Scrapeable HTTP metrics. Disabled by default; non-loopback exposure requires a separate bearer token.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "token_env": { "$ref": "#/$defs/env_name" }
      }
    },
    "graduated_trust": {
      "description": "Disabled-by-default operator criteria for bounded policy recommendations. Recommendations never activate contracts.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "kill_switch": { "type": "boolean", "default": false },
        "workspace_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/graduated_trust_criterion" }
        }
      }
    },
    "operator_identity": {
      "description": "Operator identity used by approve, reject, and apply. signed_key verifies a registered key; jwt_oidc verifies asymmetric JWT claims and Runner-attests the decision; dev_env is local-development compatibility only.",
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "allOf": [
        {
          "if": { "properties": { "provider": { "const": "signed_key" } }, "required": ["provider"] },
          "then": { "required": ["operators"] }
        },
        {
          "if": { "properties": { "provider": { "const": "jwt_oidc" } }, "required": ["provider"] },
          "then": {
            "required": ["algorithms"],
            "oneOf": [
              { "required": ["jwks_url_env"] },
              { "required": ["public_key_env"] },
              { "required": ["public_key_path"] }
            ]
          }
        }
      ],
      "properties": {
        "provider": { "enum": ["dev_env", "signed_key", "jwt_oidc"] },
        "actor_env": { "$ref": "#/$defs/env_name" },
        "roles_env": { "$ref": "#/$defs/env_name" },
        "apply_roles": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } },
        "operators": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["public_key_path", "roles"],
            "properties": {
              "public_key_path": { "type": "string", "minLength": 1 },
              "roles": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } }
            }
          }
        },
        "token_env": { "$ref": "#/$defs/env_name" },
        "token_file_env": { "$ref": "#/$defs/env_name" },
        "token_stdin": { "type": "boolean" },
        "roles_claim": { "$ref": "#/$defs/identifier" },
        "subject_claim": { "$ref": "#/$defs/identifier" },
        "attestation_secret_env": { "$ref": "#/$defs/env_name" },
        "algorithms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["RS256", "ES256"] } },
        "jwks_url_env": { "$ref": "#/$defs/env_name" },
        "public_key_env": { "$ref": "#/$defs/env_name" },
        "public_key_path": { "type": "string", "minLength": 1 },
        "issuer": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "clock_skew_seconds": { "type": "integer", "minimum": 0, "maximum": 300 },
        "jwks_cache_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "jwks_cooldown_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "fetch_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 30000 },
        "max_response_bytes": { "type": "integer", "minimum": 1024, "maximum": 10485760 }
      }
    },
    "session_auth": {
      "description": "Signed per-session identity for Streamable HTTP http_claims contexts. HS256 is retained for development; asymmetric verification uses only JWKS or public PEM material.",
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "allOf": [
        {
          "if": { "properties": { "provider": { "const": "jwt_hs256" } }, "required": ["provider"] },
          "then": { "required": ["secret_env"] }
        },
        {
          "if": { "properties": { "provider": { "const": "jwt_asymmetric" } }, "required": ["provider"] },
          "then": {
            "required": ["algorithms"],
            "oneOf": [
              { "required": ["jwks_url_env"] },
              { "required": ["public_key_env"] },
              { "required": ["public_key_path"] }
            ]
          }
        }
      ],
      "properties": {
        "provider": { "enum": ["jwt_hs256", "jwt_asymmetric"] },
        "secret_env": { "$ref": "#/$defs/env_name" },
        "previous_secret_env": { "$ref": "#/$defs/env_name" },
        "algorithms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["HS256", "RS256", "ES256"] } },
        "jwks_url_env": { "$ref": "#/$defs/env_name" },
        "public_key_env": { "$ref": "#/$defs/env_name" },
        "public_key_path": { "type": "string", "minLength": 1 },
        "issuer": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "tenant_claim": { "$ref": "#/$defs/identifier" },
        "principal_claim": { "$ref": "#/$defs/identifier" },
        "clock_skew_seconds": { "type": "integer", "minimum": 0, "maximum": 300 },
        "jwks_cache_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "jwks_cooldown_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "fetch_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 30000 },
        "max_response_bytes": { "type": "integer", "minimum": 1024, "maximum": 10485760 }
      }
    },
    "cloud": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url_env", "runner_token_env", "adapter_id"],
      "properties": {
        "base_url_env": { "$ref": "#/$defs/env_name" },
        "runner_token_env": { "$ref": "#/$defs/env_name" },
        "runner_id": { "type": "string", "minLength": 1 },
        "runner_version": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "adapter_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "engines": { "type": "array", "minItems": 1, "items": { "enum": ["postgres", "mysql"] } },
        "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "session": { "type": "object" }
      }
    }
  },
  "$defs": {
    "rate_limit_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "window_seconds"],
      "properties": {
        "requests": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "window_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      }
    },
    "graduated_trust_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability", "policy", "field", "minimum_human_reviews", "window_days",
        "maximum_rejection_rate", "maximum_conflict_rate", "maximum_failure_rate",
        "maximum_revert_rate", "maximum_threshold_increase", "absolute_ceiling"
      ],
      "properties": {
        "capability": { "$ref": "#/$defs/qualified_name" },
        "policy": { "type": "string", "minLength": 1 },
        "field": { "$ref": "#/$defs/identifier" },
        "minimum_human_reviews": { "type": "integer", "minimum": 10, "maximum": 10000 },
        "window_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "maximum_rejection_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_conflict_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_revert_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_threshold_increase": { "type": "number", "exclusiveMinimum": 0 },
        "absolute_ceiling": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "env_name": {
      "type": "string",
      "pattern": "^[A-Z_][A-Z0-9_]*$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "qualified_name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
    },
    "scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "read_url_env"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["postgres", "mysql"]
        },
        "read_url_env": {
          "description": "Environment variable containing the least-privilege read connection URL.",
          "$ref": "#/$defs/env_name"
        },
        "write_url_env": {
          "description": "Environment variable containing the separate trusted writer URL. It is never exposed over MCP.",
          "$ref": "#/$defs/env_name"
        },
        "read_only": {
          "type": "boolean"
        },
        "statement_timeout_ms": {
          "description": "Operator-controlled timeout for source reads and direct-write statement/lock waits, in milliseconds.",
          "type": "integer",
          "minimum": 1
        },
        "pool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_connections": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "connection_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 300000 },
            "idle_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 3600000 },
            "queue_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 300000 },
            "queue_limit": { "type": "integer", "minimum": 0, "maximum": 100000 }
          }
        },
        "database_scope": {
          "description": "Database-side scope enforcement. application uses Runner predicates; postgres_rls also binds trusted context into transaction-local PostgreSQL settings and requires verified RLS policies.",
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": { "const": "application" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "tenant_setting", "principal_setting"],
              "properties": {
                "mode": { "const": "postgres_rls" },
                "tenant_setting": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
                },
                "principal_setting": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
                }
              }
            }
          ]
        },
        "credential_scope": {
          "description": "Connection authority. tenant_resolver names an application-supplied resolver; it never embeds credentials.",
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": { "const": "shared" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "resolver"],
              "properties": {
                "mode": { "const": "tenant_resolver" },
                "resolver": { "$ref": "#/$defs/identifier" }
              }
            }
          ]
        },
        "receipts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["authority"],
          "properties": {
            "authority": { "enum": ["source_db", "runner_ledger"] },
            "provisioning": { "enum": ["precreated", "auto_migrate"] },
            "schema": { "$ref": "#/$defs/identifier" },
            "table": { "$ref": "#/$defs/identifier" }
          }
        },
        "ssl": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "trusted_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["static_dev", "environment", "http_claims", "cloud_session"]
        },
        "values": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "tenant_id": {
              "type": "string"
            },
            "principal": {
              "type": "string"
            },
            "tenant_id_env": {
              "$ref": "#/$defs/env_name"
            },
            "principal_env": {
              "$ref": "#/$defs/env_name"
            }
          }
        }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sql_update", "http_handler", "command_handler"]
        },
        "url_env": {
          "$ref": "#/$defs/env_name"
        },
        "method": {
          "type": "string",
          "enum": ["POST", "PUT", "PATCH"]
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "bearer_env"
            },
            "token_env": {
              "$ref": "#/$defs/env_name"
            }
          }
        },
        "signing_secret_env": {
          "$ref": "#/$defs/env_name"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "command_env": {
          "$ref": "#/$defs/env_name"
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "source", "target", "args"],
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "aggregate_read" } }, "required": ["kind"] },
          "then": { "required": ["aggregate", "evidence"] },
          "else": {
            "required": ["lookup", "visible_columns"],
            "properties": {
              "args": { "minProperties": 1 },
              "visible_columns": { "minItems": 1 }
            }
          }
        }
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/qualified_name"
        },
        "kind": {
          "type": "string",
          "enum": ["read", "aggregate_read", "proposal"]
        },
        "description": {
          "description": "Model-facing text shown in MCP tools/list. Describe when to use the tool.",
          "type": "string",
          "minLength": 1
        },
        "returns_hint": {
          "description": "Model-facing hint about what the tool returns.",
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "executor": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "args": {
          "type": "object",
          "minProperties": 0,
          "additionalProperties": {
            "$ref": "#/$defs/arg"
          }
        },
        "lookup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id_from_arg"],
          "properties": {
            "id_from_arg": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "visible_columns": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "evidence": {
          "type": "string"
        },
        "max_rows": {
          "type": "integer",
          "minimum": 1
        },
        "aggregate": {
          "$ref": "#/$defs/aggregate_read"
        },
        "patch": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/patch_binding"
          }
        },
        "operation": {
          "$ref": "#/$defs/proposal_operation"
        },
        "allowed_columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "numeric_bounds": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/numeric_bound"
          }
        },
        "transition_guards": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/transition_guard"
          }
        },
        "reversibility": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "const": "reviewed_inverse"
            }
          }
        },
        "conflict_guard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "column": {
              "$ref": "#/$defs/identifier"
            },
            "weak_guard_ack": {
              "type": "boolean"
            }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string"
            },
            "required_role": {
              "type": "string"
            },
            "required_approvals": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "policy": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "writeback": {
          "$ref": "#/$defs/writeback"
        },
        "single_tenant_dev_ack": {
          "type": "boolean"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "table", "primary_key"],
      "properties": {
        "schema": {
          "$ref": "#/$defs/identifier"
        },
        "table": {
          "$ref": "#/$defs/identifier"
        },
        "primary_key": {
          "$ref": "#/$defs/identifier"
        },
        "tenant_key": {
          "$ref": "#/$defs/identifier"
        },
        "single_tenant_dev": {
          "type": "boolean"
        }
      }
    },
    "arg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "object_array"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "max_length": {
          "type": "integer",
          "minimum": 1
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "enum": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        },
        "max_items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "fields": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 64,
          "additionalProperties": {
            "$ref": "#/$defs/arg"
          }
        }
      }
    },
    "patch_binding": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["fixed"]
        },
        {
          "required": ["from_arg"]
        },
        {
          "required": ["from_item"]
        }
      ],
      "properties": {
        "fixed": {
          "$ref": "#/$defs/scalar"
        },
        "from_arg": {
          "type": "string",
          "minLength": 1
        },
        "from_item": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "proposal_operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["update", "insert", "delete"] },
        "cardinality": { "enum": ["single", "set"] },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["column", "operator", "value"],
                "properties": {
                  "column": { "$ref": "#/$defs/identifier" },
                  "operator": { "const": "eq" },
                  "value": { "$ref": "#/$defs/scalar" }
                }
              }
            }
          }
        },
        "max_rows": { "type": "integer", "minimum": 1, "maximum": 100 },
        "aggregate_bounds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["column", "measure", "maximum"],
            "properties": {
              "column": { "$ref": "#/$defs/identifier" },
              "measure": { "enum": ["before", "after", "absolute_delta"] },
              "maximum": { "type": "number", "minimum": 0 }
            }
          }
        },
        "batch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["items_from_arg"],
          "properties": {
            "items_from_arg": { "$ref": "#/$defs/identifier" }
          }
        },
        "deduplication": {
          "type": "object",
          "additionalProperties": false,
          "required": ["components"],
          "properties": {
            "components": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["column", "source"],
                "properties": {
                  "column": { "$ref": "#/$defs/identifier" },
                  "source": { "enum": ["proposal_id", "trusted_tenant", "fixed", "item_field"] },
                  "fixed": { "$ref": "#/$defs/scalar" },
                  "item_field": { "$ref": "#/$defs/identifier" }
                }
              }
            }
          }
        },
        "version_advance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["column", "strategy"],
          "properties": {
            "column": { "$ref": "#/$defs/identifier" },
            "strategy": { "enum": ["integer_increment", "database_generated"] }
          }
        }
      }
    },
    "aggregate_read": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function", "minimum_group_size"],
      "properties": {
        "function": { "enum": ["count", "sum", "avg"] },
        "count_mode": { "enum": ["rows", "non_null"] },
        "column": { "$ref": "#/$defs/identifier" },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["column", "operator", "value"],
                "properties": {
                  "column": { "$ref": "#/$defs/identifier" },
                  "operator": { "const": "eq" },
                  "value": { "$ref": "#/$defs/scalar" }
                }
              }
            }
          }
        },
        "minimum_group_size": { "type": "integer", "minimum": 2, "maximum": 1000000 }
      }
    },
    "numeric_bound": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      }
    },
    "transition_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed"],
      "properties": {
        "from_column": {
          "$ref": "#/$defs/identifier"
        },
        "allowed": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "writeback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["direct_sql", "app_handler", "cloud_worker", "none"]
        },
        "executor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["approval", "settlement", "scope", "custom"] },
        "mode": { "type": "string" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "max"],
            "properties": {
              "field": { "$ref": "#/$defs/identifier" },
              "max": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "limits": {
          "description": "Reviewed aggregate ceilings for policy auto-approval. Exceeding one falls back to human review.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "max", "period"],
            "allOf": [
              {
                "if": { "properties": { "kind": { "const": "total" } }, "required": ["kind"] },
                "then": { "required": ["field"] },
                "else": { "not": { "required": ["field"] } }
              }
            ],
            "properties": {
              "kind": { "enum": ["count", "total"] },
              "max": { "type": "integer", "minimum": 0 },
              "period": { "const": "day" },
              "field": { "$ref": "#/$defs/identifier" },
              "scope": { "enum": ["tenant_policy", "tenant_policy_object"] }
            }
          }
        }
      }
    }
  }
}
