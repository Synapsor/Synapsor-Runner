{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapsor.ai/schemas/synapsor.runner.schema.json",
  "title": "Synapsor Runner config",
  "description": "Configuration for local Synapsor Runner MCP capabilities over Postgres/MySQL.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode"],
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "cloud" } }, "required": ["mode"] },
      "then": { "required": ["cloud"] },
      "else": { "required": ["sources"] }
    },
    {
      "if": { "required": ["contracts"] },
      "then": {},
      "else": {
        "if": { "properties": { "mode": { "not": { "const": "cloud" } } }, "required": ["mode"] },
        "then": {
          "required": ["capabilities"],
          "properties": { "capabilities": { "minItems": 1 } },
          "anyOf": [
            { "required": ["trusted_context"] },
            { "required": ["contexts"] }
          ]
        }
      }
    }
  ],
  "properties": {
    "version": {
      "description": "Runner configuration contract version. Version 1 is the current public format.",
      "const": 1
    },
    "mode": {
      "description": "Local execution mode. review permits proposals and trusted writeback; cloud delegates reviewed tools to Synapsor Cloud.",
      "type": "string",
      "enum": ["read_only", "shadow", "review", "cloud"]
    },
    "result_format": {
      "description": "Set to 2 to return one stable ok/summary/data/proposal/error envelope from MCP tool calls.",
      "type": "integer",
      "enum": [1, 2],
      "default": 1
    },
    "strict": {
      "description": "Reject unknown configuration keys when true.",
      "type": "boolean",
      "default": true
    },
    "storage": {
      "description": "Local proposal, evidence, receipt, and replay ledger. Relative sqlite_path values resolve from the Runner process working directory.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sqlite_path": {
          "description": "SQLite ledger path. The file can contain visible business-data evidence and is created with owner-only permissions on POSIX.",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sources": {
      "description": "Named Postgres/MySQL sources. Contract SOURCE names must match these keys.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/source"
      }
    },
    "trusted_context": {
      "description": "Default operator-controlled tenant/principal binding. These values are never model arguments.",
      "$ref": "#/$defs/trusted_context"
    },
    "contexts": {
      "description": "Named trusted contexts referenced by capabilities or portable contracts.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/trusted_context"
      }
    },
    "executors": {
      "description": "Trusted app-owned writeback executors. URLs, tokens, and commands are referenced through environment-variable names.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/executor"
      }
    },
    "contracts": {
      "description": "Portable @synapsor/spec contract files. Relative paths resolve from this config file's directory.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capabilities": {
      "description": "Embedded compatibility capabilities. May be empty when contracts supplies the capability catalog.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "policies": {
      "description": "Embedded reviewed policies. Contract-authored policies are merged into the same runtime catalog.",
      "type": "array",
      "items": { "$ref": "#/$defs/policy" }
    },
    "approvals": {
      "description": "Local approval behavior overrides.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disable_auto_approval": { "type": "boolean" }
      }
    },
    "cloud": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url_env", "runner_token_env", "adapter_id"],
      "properties": {
        "base_url_env": { "$ref": "#/$defs/env_name" },
        "runner_token_env": { "$ref": "#/$defs/env_name" },
        "runner_id": { "type": "string", "minLength": 1 },
        "runner_version": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "adapter_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "engines": { "type": "array", "minItems": 1, "items": { "enum": ["postgres", "mysql"] } },
        "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "session": { "type": "object" }
      }
    }
  },
  "$defs": {
    "env_name": {
      "type": "string",
      "pattern": "^[A-Z_][A-Z0-9_]*$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "qualified_name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
    },
    "scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "read_url_env"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["postgres", "mysql"]
        },
        "read_url_env": {
          "description": "Environment variable containing the least-privilege read connection URL.",
          "$ref": "#/$defs/env_name"
        },
        "write_url_env": {
          "description": "Environment variable containing the separate trusted writer URL. It is never exposed over MCP.",
          "$ref": "#/$defs/env_name"
        },
        "read_only": {
          "type": "boolean"
        },
        "statement_timeout_ms": {
          "description": "Per-read database statement timeout in milliseconds.",
          "type": "integer",
          "minimum": 1
        },
        "ssl": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "trusted_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["static_dev", "environment", "http_claims", "cloud_session"]
        },
        "values": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "tenant_id": {
              "type": "string"
            },
            "principal": {
              "type": "string"
            },
            "tenant_id_env": {
              "$ref": "#/$defs/env_name"
            },
            "principal_env": {
              "$ref": "#/$defs/env_name"
            }
          }
        }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sql_update", "http_handler", "command_handler"]
        },
        "url_env": {
          "$ref": "#/$defs/env_name"
        },
        "method": {
          "type": "string",
          "enum": ["POST", "PUT", "PATCH"]
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "bearer_env"
            },
            "token_env": {
              "$ref": "#/$defs/env_name"
            }
          }
        },
        "signing_secret_env": {
          "$ref": "#/$defs/env_name"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "command_env": {
          "$ref": "#/$defs/env_name"
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "source", "target", "args", "lookup", "visible_columns"],
      "properties": {
        "name": {
          "$ref": "#/$defs/qualified_name"
        },
        "kind": {
          "type": "string",
          "enum": ["read", "proposal"]
        },
        "description": {
          "description": "Model-facing text shown in MCP tools/list. Describe when to use the tool.",
          "type": "string",
          "minLength": 1
        },
        "returns_hint": {
          "description": "Model-facing hint about what the tool returns.",
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "executor": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "args": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/arg"
          }
        },
        "lookup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id_from_arg"],
          "properties": {
            "id_from_arg": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "visible_columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "evidence": {
          "type": "string"
        },
        "max_rows": {
          "type": "integer",
          "minimum": 1
        },
        "patch": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/patch_binding"
          }
        },
        "allowed_columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "numeric_bounds": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/numeric_bound"
          }
        },
        "transition_guards": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/transition_guard"
          }
        },
        "conflict_guard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "column": {
              "$ref": "#/$defs/identifier"
            },
            "weak_guard_ack": {
              "type": "boolean"
            }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string"
            },
            "required_role": {
              "type": "string"
            },
            "policy": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "writeback": {
          "$ref": "#/$defs/writeback"
        },
        "single_tenant_dev_ack": {
          "type": "boolean"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "table", "primary_key"],
      "properties": {
        "schema": {
          "$ref": "#/$defs/identifier"
        },
        "table": {
          "$ref": "#/$defs/identifier"
        },
        "primary_key": {
          "$ref": "#/$defs/identifier"
        },
        "tenant_key": {
          "$ref": "#/$defs/identifier"
        },
        "single_tenant_dev": {
          "type": "boolean"
        }
      }
    },
    "arg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "max_length": {
          "type": "integer",
          "minimum": 1
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "enum": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        }
      }
    },
    "patch_binding": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["fixed"]
        },
        {
          "required": ["from_arg"]
        }
      ],
      "properties": {
        "fixed": {
          "$ref": "#/$defs/scalar"
        },
        "from_arg": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "numeric_bound": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      }
    },
    "transition_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed"],
      "properties": {
        "from_column": {
          "$ref": "#/$defs/identifier"
        },
        "allowed": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "writeback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["direct_sql", "app_handler", "cloud_worker", "none"]
        },
        "executor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["approval", "settlement", "scope", "custom"] },
        "mode": { "type": "string" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "max"],
            "properties": {
              "field": { "$ref": "#/$defs/identifier" },
              "max": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
