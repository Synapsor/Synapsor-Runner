{
  "mcpServers": {
    "synapsor": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "@synapsor/runner@1.6.2",
        "synapsor-runner",
        "mcp",
        "serve",
        "--config",
        "${workspaceFolder}/synapsor.runner.json",
        "--store",
        "${workspaceFolder}/.synapsor/local.db"
      ]
    }
  }
}
